# ─── DATABASE ────────────────────────────────────────────────────
POSTGRES_PASSWORD=postgres123
DATABASE_URL=postgresql+asyncpg://postgres:postgres123@localhost:5432/meeting_kb

# ─── REDIS ───────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── SECURITY ────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here-64-chars-minimum-generate-with-python

# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=your-fernet-key-here-base64-encoded

# ─── APP ─────────────────────────────────────────────────────────
APP_ENV=development
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
ALLOWED_ORIGINS=http://localhost:3000

# ─── FRONTEND ────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

# ─── GOOGLE OAUTH (for Drive integration) ────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/integrations/google-drive/callback
